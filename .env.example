# Claude Telegram Bot
# Environment Configuration

# ==============================================================================
# REQUIRED
# ==============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=1234567890:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789

# ==============================================================================
# RECOMMENDED
# ==============================================================================

# Working directory where Claude runs (loads CLAUDE.md, skills, MCP config)
CLAUDE_WORKING_DIR=/path/to/your/projects

# ==============================================================================
# OPTIONAL - Group Chat Support
# ==============================================================================

# Comma-separated Telegram group IDs allowed to interact with the bot
# The bot responds only to @mentions or replies in whitelisted groups
# Find your group ID: add @getmyid_bot to the group
# TELEGRAM_ALLOWED_GROUPS=-1001234567890

# ==============================================================================
# OPTIONAL - Alert Socket (requires group support)
# ==============================================================================

# Unix socket path for local alert ingestion
# Local scripts can send JSON alerts via socat to trigger Claude autonomously
# Requires TELEGRAM_ALLOWED_GROUPS to be set (alerts are posted to the first group)
# ALERT_SOCKET_PATH=/run/cc-telegram-bot/alerts.sock

# Shared secret for socket authentication (optional)
# ALERT_SOCKET_SECRET=

# ==============================================================================
# OPTIONAL - Daily Report (EOD Logbook)
# ==============================================================================

# Directory where daily bot activity logs are written
# Claude generates a Markdown report at the configured timer time (default: 23:55)
# Default: ~/Documents/bot-logs
# DAILY_LOG_DIR=/path/to/bot-logs

# ==============================================================================
# OPTIONAL - Security
# ==============================================================================

# Comma-separated paths Claude can access
# Default: working dir, ~/Documents, ~/Downloads, ~/Desktop, ~/.claude
# Note: Setting this OVERRIDES defaults. Include ~/.claude for plan mode to work.
# ALLOWED_PATHS=/path/to/projects,/path/to/documents,~/.claude

# Rate limiting (token bucket)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# OPTIONAL - Claude Authentication
# ==============================================================================

# API key for environments without Claude Code CLI auth
# Get from: https://console.anthropic.com/
# Note: API usage is billed per token - CLI auth is more cost-effective
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Default Claude model
# CLAUDE_MODEL=claude-sonnet-4-5

# Path to Claude CLI (auto-detected from PATH by default)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# ==============================================================================
# OPTIONAL - Extended Thinking
# ==============================================================================

# Keywords that trigger extended thinking (comma-separated, case-insensitive)
# Values with spaces MUST be quoted (source .env parses them as shell commands)
# THINKING_KEYWORDS="think,denke,nachdenken"

# Keywords that trigger deep thinking (50k tokens)
# THINKING_DEEP_KEYWORDS="ultrathink,denke genau,think hard"

# ==============================================================================
# OPTIONAL - Voice Transcription
# ==============================================================================

# Transcription mode: "local" (whisper-cli) or "off" (disabled)
# Default: "local" — uses whisper.cpp with local GGML model (no data leaves the machine)
# Requires: brew install whisper-cpp + GGML model in models/
# WHISPER_MODE=local

# Whisper language (ISO 639-1 code)
# Default: "de" (German)
# WHISPER_LANGUAGE=de

# Path to GGML whisper model
# Default: models/ggml-large-v3-turbo-q5_0.bin (relative to project root)
# WHISPER_MODEL_PATH=/path/to/ggml-model.bin

# Path to whisper-cli binary
# Default: auto-detected via PATH, fallback /opt/homebrew/bin/whisper-cli
# WHISPER_CLI_PATH=/opt/homebrew/bin/whisper-cli

# ==============================================================================
# OPTIONAL - Alert History Database
# ==============================================================================

# SQLite database for alert history (trend analysis, MTTR metrics, data-driven reports)
# Every incoming alert is persisted — does not affect queue or processing flow
# Default: ~/.cc-telegram-bot/alerts.db
# ALERT_DB_PATH=~/.cc-telegram-bot/alerts.db

# ==============================================================================
# OPTIONAL - Logging
# ==============================================================================

# Audit log path
# AUDIT_LOG_PATH=~/.cc-telegram-bot/audit.log

# Output audit logs as JSON (default: true, prevents log injection)
# AUDIT_LOG_JSON=true

# HMAC key for audit log integrity (auto-generated per session if not set)
# Set this for persistent verification across restarts
# AUDIT_LOG_HMAC_KEY=your-secret-hmac-key

# Max audit log size before rotation (default: 10MB)
# AUDIT_LOG_MAX_SIZE=10485760

# Number of rotated log files to keep (default: 5)
# AUDIT_LOG_MAX_FILES=5
